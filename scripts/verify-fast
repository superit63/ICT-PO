#!/usr/bin/env bash
set -euo pipefail
SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd -P)"
cd -- "$SCRIPT_DIR/.."
if [[ ! -x sale-stock-po-app/node_modules/.bin/eslint ]]; then
  echo "verify-fast: local sale-stock-po-app dependencies are unavailable" >&2
  exit 2
fi
npm --prefix sale-stock-po-app run lint
